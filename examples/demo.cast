[0.070, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.000, "o", "\r\n\u001b[2m# coffeeshop: a tiny repo. four tests, all green. one landed branch, managed by cafecito.\u001b(B\u001b[m\r\n"]
[1.407, "o", "\u001b[1m$ cafecito init --repo /var/folders/pd/332czfqn0cvbvyq2rk3_h66m0000gn/T//cafecito-demo-nH2e1p/coffeeshop --test-cmd python3 -m pytest -q -p no:cacheprovider\u001b(B\u001b[m\r\n"]
[0.108, "o", "cafecito initialized on /private/var/folders/pd/332czfqn0cvbvyq2rk3_h66m0000gn/T/cafecito-demo-nH2e1p/coffeeshop\r\n  landed branch : cafecito/main\r\n  tip           : 272c646888fa\r\n  test command  : python3 -m pytest -q -p no:cacheprovider\r\n  require signal: False\r\n\r\nconnect an agent:\r\n  claude mcp add cafecito -- cafecito serve --repo /private/var/folders/pd/332czfqn0cvbvyq2rk3_h66m0000gn/T/cafecito-demo-nH2e1p/coffeeshop\r\n"]
[1.411, "o", "\r\n\u001b[2m# three agents start from the SAME commit. no coordination. nobody will ever rebase.\u001b(B\u001b[m\r\n"]
[1.727, "o", "\r\n\u001b[2m# agent-espresso hardened brew(). agent-croissant priced oat milk. agent-oatmilk added cup sizes.\u001b(B\u001b[m\r\n"]
[1.408, "o", "\r\n\u001b[2m# espresso submits — gate runs the tests, then it lands:\u001b(B\u001b[m\r\n"]
[1.410, "o", "\u001b[1m$ cafecito submit 8e4d6e05c630e360cf25c7cb0e39bd2b50b15568 --repo /var/folders/pd/332czfqn0cvbvyq2rk3_h66m0000gn/T//cafecito-demo-nH2e1p/coffeeshop --agent agent-espresso --title brew(): reject empty orders\u001b(B\u001b[m\r\n"]
[0.267, "o", "{\r\n \"verdict\": \"landed\",\r\n \"id\": \"cs_d73bf1f21e\",\r\n \"tip\": \"f0cf1f52e9b5b8f2055ba155c97867275e89e2b3\",\r\n \"regenerated\": false,\r\n \"gate\": {\r\n  \"green\": true,\r\n  \"no_signal\": false,\r\n  \"seconds\": 0.1,\r\n  \"summary\": \"..                                                                       [100%]\\n2 passed in 0.00s\",\r\n  \"tests\": [\r\n   \"tests/test_orders.py\"\r\n  ]\r\n }\r\n}\r\n"]
[1.411, "o", "\r\n\u001b[2m# croissant touched different symbols — it COMMUTES. no rebase, no waiting, no re-testing espresso:\u001b(B\u001b[m\r\n"]
[1.408, "o", "\u001b[1m$ cafecito submit 1bd4811c7f97b28dd61fb6f7c5031a636a8e4593 --repo /var/folders/pd/332czfqn0cvbvyq2rk3_h66m0000gn/T//cafecito-demo-nH2e1p/coffeeshop --agent agent-croissant --title price(): oat milk surcharge\u001b(B\u001b[m\r\n"]
[0.277, "o", "{\r\n \"verdict\": \"landed\",\r\n \"id\": \"cs_131b3c08eb\",\r\n \"tip\": \"3552e733d4a15e248adb835c2d0b49a597c9c8e5\",\r\n \"regenerated\": false,\r\n \"gate\": {\r\n  \"green\": true,\r\n  \"no_signal\": false,\r\n  \"seconds\": 0.1,\r\n  \"summary\": \"..                                                                       [100%]\\n2 passed in 0.00s\",\r\n  \"tests\": [\r\n   \"tests/test_menu.py\"\r\n  ]\r\n }\r\n}\r\n"]
[1.411, "o", "\r\n\u001b[2m# oatmilk rewrote the SAME function espresso just changed. a merge queue would bounce it back.\u001b(B\u001b[m\r\n"]
[1.409, "o", "\r\n\u001b[2m# here, nobody resolves anything: a reconciler regenerates brew() from BOTH intents, then the gate decides…\u001b(B\u001b[m\r\n"]
[1.409, "o", "\u001b[1m$ cafecito submit 67e5d4e6e5c1b7a3c15ad8d80e24061bcfc62740 --repo /var/folders/pd/332czfqn0cvbvyq2rk3_h66m0000gn/T//cafecito-demo-nH2e1p/coffeeshop --agent agent-oatmilk --title brew(): cup sizes\u001b(B\u001b[m\r\n"]
